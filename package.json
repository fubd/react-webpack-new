{
  "name": "parrot-platform",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspace @parrot/frontend",
    "build:frontend": "npm run build --workspace @parrot/frontend",
    "type-check": "npm run type-check --workspace @parrot/frontend && npm run type-check --workspace @parrot/backend",
    "lint": "npm run lint --workspace @parrot/frontend && npm run lint --workspace @parrot/backend",
    "dev:backend": "npm run dev --workspace @parrot/backend",
    "migrate": "npm run migrate --workspace @parrot/backend"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.6.1",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.5.0",
    "typescript-eslint": "^8.49.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
