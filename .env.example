APP_NAME=Parrot
NODE_ENV=development
VERSION=latest

FRONTEND_PORT=26030
BACKEND_PORT=26031
MYSQL_PORT=26032
NGINX_PORT=26033

DATABASE_HOST=127.0.0.1
DATABASE_PORT=26032
MYSQL_DATABASE=parrot
MYSQL_USER=parrot
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-root-password

# Backup settings (used by make db-backup / make setup-backup-cron)
BACKUP_RETENTION_DAYS=7
BACKUP_SCHEDULE=0 3 * * *

ALIYUN_REGISTRY=registry.cn-hangzhou.aliyuncs.com
IMAGE_NAMESPACE=your-acr-namespace
ALIYUN_USERNAME=your-acr-username
ALIYUN_PASSWORD=your-acr-password

REMOTE_HOST=root@example.com
REMOTE_PATH=/root/app/parrot
